# BioClaw .env template. Copy to .env and fill in the values marked CHANGEME.
#
# Quick start: cp .env.example .env && nano .env
#
# Required to fill: AUTH_SECRET, IRC_CHANNEL, IRC_USER, the API key matching
# LLM_PROVIDER, and the BioKG backend block for your deployment.

# ─── Communication channel ──────────────────────────────────────────────────
# Pick exactly ONE.
COMMCHANNEL=irc
# Options: irc | telegram

# ─── When COMMCHANNEL=irc (works in regions where Telegram is blocked) ──────
# QuakeNet is free; channel name should be unique to avoid collisions.
# Two-# prefix means an ad-hoc unregistered channel, which is what you want.
# Generate suffixes with: echo "##bioclaw-$(openssl rand -hex 4)"
IRC_CHANNEL=##bioclaw-CHANGEME
IRC_USER=bioclaw-bot-CHANGEME
IRC_SERVER=irc.quakenet.org
IRC_PORT=6667

# ─── When COMMCHANNEL=telegram ──────────────────────────────────────────────
TG_BOT_TOKEN=

# ─── LLM ────────────────────────────────────────────────────────────────────
LLM_PROVIDER=OpenRouter
# Options: Anthropic | OpenAI | ASICloud | ASIOne | OpenRouter
# Shared OpenRouter keys must only be used with the hard-coded GLM-5.1 model
# (`z-ai/glm-5.1`) configured in overlay/lib_llm_ext.py.

EMBED_PROVIDER=Local
# Options: Local | OpenAI

# llm = GLM-5.1 rewrites grounded tool results into concise natural language.
# interpreted = deterministic formatter; raw = mechanical tool output.
BIOCLAW_ANSWER_STYLE=llm
BIOCLAW_INTERPRETER_PROVIDER=OpenRouter
BIOCLAW_INTERPRETER_MAX_TOKENS=450
BIOCLAW_LLM_ROUTING=true
BIOCLAW_ROUTER_PROVIDER=OpenRouter

# Fill in ONLY the key matching LLM_PROVIDER above; leave others blank.
ASI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ASIONE_API_KEY=
OPENROUTER_API_KEY=

# ─── Auth ───────────────────────────────────────────────────────────────────
# Random string. Generate with: openssl rand -base64 24 | tr -d '\n=' | head -c 32
AUTH_SECRET=CHANGEME

# ─── BioKG backend ──────────────────────────────────────────────────────────
# Current BioClaw deployments use the MORK/MeTTa backend. Raw Cypher queries are
# not supported on this path; BioKG access is through biokg-* skills and schema-
# aware MeTTa pattern matching.
BIOKG_BACKEND=mork
MORK_URI=http://mork:PORT
MORK_NAMESPACE=default

# Legacy Neo4j compatibility remains in biokg.py for older local experiments.
# Leave these blank unless you intentionally set BIOKG_BACKEND=neo4j.
NEO4J_URI=bolt://biocypher-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ─── Schema config ──────────────────────────────────────────────────────────
# BioCypher-format YAML describing the entity + edge types loaded into BioKG.
# Default: bundled minimal schema at /opt/bioclaw/config/schema.yaml.
# Override to point at the full BioCypher schema_config.yaml:
#   BIOCLAW_SCHEMA_FILE=/mnt/.../biocypher-kg/config/hsa/hsa_schema_config.yaml
#
# The loader extracts each node's `input_label` (BioKG/MORK label) and the
# property annotated `biolink: name` (with is_a inheritance), plus each edge's
# `input_label`/`output_label`, `source`, `target`. Used for typed lookups,
# schema-neighbor routing, source aggregation, and biokg-stage validation.
BIOCLAW_SCHEMA_FILE=/opt/bioclaw/config/schema.yaml

# Override the auto-derived list only if your KG has unusual property names.
# When BIOCLAW_NAME_PROPERTIES is empty the schema loader fills this in.
BIOCLAW_NAME_PROPERTIES=

# ─── Data-source registry ───────────────────────────────────────────────────
# Maps source tokens that appear on BioKG atoms/edges (e.g. `gaf`, `GENCODE`,
# `Gene Ontology`) to their canonical name + URL(s). Used by biokg-provenance
# and interpreted answers to print readable strings instead of bare tokens.
#
# Default: bundled minimal registry at /opt/bioclaw/config/data_sources.yaml.
# Override to point at the upstream biocypher-kg config:
#   BIOCLAW_DATASOURCE_FILE=/path/biocypher-kg/config/hsa/hsa_data_source_config.yaml
BIOCLAW_DATASOURCE_FILE=/opt/bioclaw/config/data_sources.yaml

# ─── Answer style ───────────────────────────────────────────────────────────
# interpreted = natural-language specialist summaries grounded in the raw tool
# output; raw = older mechanical outputs for debugging and regression checks.
BIOCLAW_ANSWER_STYLE=interpreted

# ─── Multi-hop lookup (auto-derived from schema, no hardcoded chains) ──────
# biokg-lookup also returns entities reachable via 2..MAX_DEPTH hops, walking
# ONLY edges declared in the schema. The schema's edge inventory is the
# allow-list — no chain enumeration needed. Set MAX_DEPTH=1 to disable.
BIOKG_LOOKUP_MAX_DEPTH=2
BIOKG_LOOKUP_MULTIHOP_LIMIT=10
