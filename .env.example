# BioClaw .env template. Copy to .env and fill in the values marked CHANGEME.
#
# Quick start: cp .env.example .env && nano .env
#
# Required to fill: AUTH_SECRET, IRC_CHANNEL, IRC_USER, the API key matching
# LLM_PROVIDER, and (once your KG is loaded) the NEO4J_* block.

# ─── Communication channel ──────────────────────────────────────────────────
# Pick exactly ONE.
COMMCHANNEL=irc
# Options: irc | telegram

# ─── When COMMCHANNEL=irc (works in regions where Telegram is blocked) ──────
# QuakeNet is free; channel name should be unique to avoid collisions.
# Two-# prefix means an ad-hoc unregistered channel, which is what you want.
# Generate suffixes with: echo "##bioclaw-$(openssl rand -hex 4)"
IRC_CHANNEL=##bioclaw-CHANGEME
IRC_USER=bioclaw-bot-CHANGEME
IRC_SERVER=irc.quakenet.org
IRC_PORT=6667

# ─── When COMMCHANNEL=telegram ──────────────────────────────────────────────
TG_BOT_TOKEN=

# ─── LLM ────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ASICloud
# Options: Anthropic | OpenAI | ASICloud | ASIOne
# Note: ASICloud (Minimax) is cheap but unreliable for the agentic loop.
# Switch to Anthropic or OpenAI for the Conductor when you have access.

EMBED_PROVIDER=Local
# Options: Local | OpenAI

# Fill in ONLY the key matching LLM_PROVIDER above; leave others blank.
ASI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ASIONE_API_KEY=

# ─── Auth ───────────────────────────────────────────────────────────────────
# Random string. Generate with: openssl rand -base64 24 | tr -d '\n=' | head -c 32
AUTH_SECRET=CHANGEME

# ─── BioKG (Phase 2A) ───────────────────────────────────────────────────────
# Leave BIOKG_BACKEND=disabled until your Neo4j is loaded and reachable.
# When the BioCypher KG is loaded, switch to BIOKG_BACKEND=neo4j.
BIOKG_BACKEND=disabled

# Neo4j connection. NEO4J_URI uses the container name + INTERNAL port (7687)
# when both BioClaw and Neo4j are on the same docker network. The HOST port
# mapping (e.g. 7688) doesn't apply between containers.
#
# Setup checklist if Neo4j is in a separate compose project:
#   docker network connect bioclaw_default biocypher-neo4j
#
# Profile examples — switch the active one by uncommenting:
#
#   # Local BioCypher Neo4j (same host, separate compose project)
#   NEO4J_URI=bolt://biocypher-neo4j:7687
#
#   # Remote Rejuve.Bio Neo4j (via VPN / public)
#   #NEO4J_URI=bolt+s://kg.rejuve.bio:7687
#
#   # Neo4j Aura (managed)
#   #NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=bolt://biocypher-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ─── Schema config (Phase 3) ────────────────────────────────────────────────
# BioCypher-format YAML describing the entity + edge types loaded into Neo4j.
# Default: bundled minimal schema at /opt/bioclaw/config/schema.yaml.
# Override to point at the full BioCypher schema_config.yaml:
#   BIOCLAW_SCHEMA_FILE=/mnt/.../biocypher-kg/config/hsa/hsa_schema_config.yaml
#
# The loader extracts each node's `input_label` (Neo4j label) and the property
# annotated `biolink: name` (with is_a inheritance), plus each edge's
# `input_label`/`output_label`, `source`, `target`. Used for typed lookups
# and biokg-stage validation.
BIOCLAW_SCHEMA_FILE=/opt/bioclaw/config/schema.yaml

# Override the auto-derived list only if your KG has unusual property names.
# When BIOCLAW_NAME_PROPERTIES is empty the schema loader fills this in.
BIOCLAW_NAME_PROPERTIES=

# ─── Data-source registry (Phase 3) ─────────────────────────────────────────
# Maps source tokens that appear on Neo4j nodes/edges (e.g. `gaf`, `GENCODE`,
# `Gene Ontology`) to their canonical name + URL(s). Used by biokg-provenance
# to print readable strings like 'GO Annotation File (GAF) <url>' instead of
# bare `gaf`, and exposed via the `biokg-source` skill.
#
# Default: bundled minimal registry at /opt/bioclaw/config/data_sources.yaml.
# Override to point at the upstream biocypher-kg config:
#   BIOCLAW_DATASOURCE_FILE=/path/biocypher-kg/config/hsa/hsa_data_source_config.yaml
BIOCLAW_DATASOURCE_FILE=/opt/bioclaw/config/data_sources.yaml

# ─── Future: MORK / AtomSpace backend (Phase 3+) ────────────────────────────
MORK_URI=
