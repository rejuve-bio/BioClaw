# BioClaw Symbolic environment template.
#
# This branch does not start IRC/Telegram agents. It queries an existing MORK
# BioAtomspace and a matching BioCypher schema.

MORK_URL=http://localhost:8037
MORK_NAMESPACE=annotation

# Full BioCypher schema for the atomspace you loaded.
BIOCLAW_SCHEMA_FILE=/path/to/biocypher-kg/config/hsa/hsa_schema_config.yaml

# Optional policy for bounded symbolic reasoning.
BIOCLAW_REASONING_FILE=config/reasoning.yaml
