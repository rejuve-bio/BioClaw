# BioClaw .env template. Copy to .env and fill in values.
#
# Pick exactly ONE communication channel:
COMMCHANNEL=irc
# Options: irc | telegram

# ─── When COMMCHANNEL=irc (works in regions where Telegram is blocked) ──────
# QuakeNet is free; channel name should be unique. Two-# prefix = "any user
# can create on the fly", one-# prefix = registered/persistent channel.
IRC_CHANNEL=##bioclaw-CHANGEME
IRC_USER=bioclaw-bot-CHANGEME
IRC_SERVER=irc.quakenet.org
IRC_PORT=6667

# ─── When COMMCHANNEL=telegram ──────────────────────────────────────────────
TG_BOT_TOKEN=

# ─── LLM ────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ASICloud
# Options: Anthropic | OpenAI | ASICloud | ASIOne

EMBED_PROVIDER=Local
# Options: Local | OpenAI

# Fill in ONLY the key matching LLM_PROVIDER above; leave others blank.
ASI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ASIONE_API_KEY=

# ─── Auth ───────────────────────────────────────────────────────────────────
# Random string. Generate with: openssl rand -base64 24 | tr -d '\n=' | head -c 32
AUTH_SECRET=CHANGEME

# ─── BioKG (Phase 2A) ───────────────────────────────────────────────────────
# Leave BIOKG_BACKEND=disabled until your Neo4j is loaded and reachable.
BIOKG_BACKEND=disabled
# When ready, switch to neo4j and fill in the connection:
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# Override only if your BioCypher schema uses unusual property names:
BIOKG_NAME_PROPERTIES=
# Future: MORK / AtomSpace backend
MORK_URI=
