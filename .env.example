# BioClaw .env template. Copy to .env and fill in the values marked CHANGEME.
#
# Quick start: cp .env.example .env && nano .env
#
# Required to fill: AUTH_SECRET, IRC_CHANNEL, IRC_USER, the API key matching
# LLM_PROVIDER, and (once your KG is loaded) the NEO4J_* block.

# ─── Communication channel ──────────────────────────────────────────────────
# Pick exactly ONE.
COMMCHANNEL=irc
# Options: irc | telegram

# ─── When COMMCHANNEL=irc (works in regions where Telegram is blocked) ──────
# QuakeNet is free; channel name should be unique to avoid collisions.
# Two-# prefix means an ad-hoc unregistered channel, which is what you want.
# Generate suffixes with: echo "##bioclaw-$(openssl rand -hex 4)"
IRC_CHANNEL=##bioclaw-CHANGEME
IRC_USER=bioclaw-bot-CHANGEME
IRC_SERVER=irc.quakenet.org
IRC_PORT=6667

# ─── When COMMCHANNEL=telegram ──────────────────────────────────────────────
TG_BOT_TOKEN=

# ─── LLM ────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ASICloud
# Options: Anthropic | OpenAI | ASICloud | ASIOne
# Note: ASICloud (Minimax) is cheap but unreliable for the agentic loop.
# Switch to Anthropic or OpenAI for the Conductor when you have access.

EMBED_PROVIDER=Local
# Options: Local | OpenAI

# Fill in ONLY the key matching LLM_PROVIDER above; leave others blank.
ASI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ASIONE_API_KEY=

# ─── Auth ───────────────────────────────────────────────────────────────────
# Random string. Generate with: openssl rand -base64 24 | tr -d '\n=' | head -c 32
AUTH_SECRET=CHANGEME

# ─── BioKG (Phase 2A) ───────────────────────────────────────────────────────
# Leave BIOKG_BACKEND=disabled until your Neo4j is loaded and reachable.
# When the BioCypher KG is loaded, switch to BIOKG_BACKEND=neo4j.
BIOKG_BACKEND=disabled

# Neo4j connection. NEO4J_URI uses the container name + INTERNAL port (7687)
# when both BioClaw and Neo4j are on the same docker network. The HOST port
# mapping (e.g. 7688) doesn't apply between containers.
#
# Setup checklist if Neo4j is in a separate compose project:
#   docker network connect bioclaw_default biocypher-neo4j
NEO4J_URI=bolt://biocypher-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Properties to probe when matching an entity by name in biokg-lookup.
# Defaults match the BioCypher human-schema convention:
#   gene → gene_name
#   protein → protein_name
#   transcript → transcript_name
#   pathway → pathway_name
#   GO terms (BP/MF/CC) and disease → term_name (inherited from "ontology term")
#   fallback → id
# Override only if your schema uses different property names.
BIOKG_NAME_PROPERTIES=gene_name,protein_name,transcript_name,pathway_name,term_name,id

# ─── Future: MORK / AtomSpace backend (Phase 3+) ────────────────────────────
MORK_URI=
