#!/usr/bin/env bash
# BioClaw Phase 0 launcher.
# Prompts once for Telegram bot token + LLM provider+key, writes a .env file,
# builds the image, and brings up the 3-service compose stack.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ENV_FILE="$ROOT/.env"

cd "$ROOT"

print_banner() {
  cat <<'EOF'

============================================
  BioClaw Phase 0 Launcher
  3 OmegaClaw agents:
    - conductor      (Telegram, talks to you)
    - query-oc       (internal-rpc, BioKG queries — stub)
    - annotation-oc  (internal-rpc, annotations  — stub)
============================================

EOF
}

prompt_telegram_token() {
  while true; do
    read -r -s -p "Paste the Telegram bot token for the Conductor (or 'q' to quit): " token
    echo
    if [ "$token" = "q" ]; then exit 1; fi
    if [ -z "$token" ]; then
      echo "Token is required." >&2
      continue
    fi
    # Validate
    local me
    me=$(curl -sf "https://api.telegram.org/bot${token}/getMe" || true)
    if ! echo "$me" | grep -q '"ok":true'; then
      echo "Telegram getMe failed — check the token. Server said: $me" >&2
      continue
    fi
    local username
    username=$(echo "$me" | sed -n 's/.*"username":"\([^"]*\)".*/\1/p')
    echo "Bot validated. Talk to it at: https://t.me/${username}"
    TG_BOT_TOKEN="$token"
    return
  done
}

prompt_provider() {
  cat <<'EOF'
Select LLM provider:
  1) Anthropic
  2) OpenAI
  3) ASI Cloud (Minimax)
  4) ASI:One
  5) OpenRouter (GLM-5.1 only)
EOF
  while true; do
    read -r -p "Enter 1-5 (default: 5): " c
    case "${c:-5}" in
      1) LLM_PROVIDER="Anthropic"; EMBED_PROVIDER="Local"; API_TOKEN_VAR="ANTHROPIC_API_KEY"; return ;;
      2) LLM_PROVIDER="OpenAI";    EMBED_PROVIDER="OpenAI"; API_TOKEN_VAR="OPENAI_API_KEY";    return ;;
      3) LLM_PROVIDER="ASICloud";  EMBED_PROVIDER="Local"; API_TOKEN_VAR="ASI_API_KEY";        return ;;
      4) LLM_PROVIDER="ASIOne";    EMBED_PROVIDER="Local"; API_TOKEN_VAR="ASIONE_API_KEY";     return ;;
      5) LLM_PROVIDER="OpenRouter"; EMBED_PROVIDER="Local"; API_TOKEN_VAR="OPENROUTER_API_KEY"; return ;;
      *) echo "Please enter 1-5." >&2 ;;
    esac
  done
}

prompt_api_key() {
  while true; do
    read -r -s -p "Paste the LLM API key for $LLM_PROVIDER (shared by all 3 agents): " key
    echo
    if [ -z "$key" ]; then
      echo "Key is required." >&2
      continue
    fi
    API_TOKEN="$key"
    return
  done
}

write_env_file() {
  umask 077
  # Write the API key under its actual env var name (e.g. ASI_API_KEY=...)
  # so docker compose can forward it. Compose doesn't interpolate variables
  # used as YAML keys, so we can't do `${API_TOKEN_VAR}: ${API_TOKEN}`.
  cat >"$ENV_FILE" <<EOF
LLM_PROVIDER=${LLM_PROVIDER}
EMBED_PROVIDER=${EMBED_PROVIDER}
TG_BOT_TOKEN=${TG_BOT_TOKEN}
AUTH_SECRET=$(openssl rand -base64 24 2>/dev/null | tr -d '\n=' | head -c 32 || echo "bioclaw-dev-secret")
${API_TOKEN_VAR}=${API_TOKEN}
EOF
  chmod 600 "$ENV_FILE"
}

build_and_up() {
  echo
  echo "Building bioclaw:phase0 image (first time may take a couple minutes)..."
  docker compose build
  echo
  echo "Bringing up the stack..."
  docker compose up -d
  echo
  echo "============================================"
  echo " Stack is up. Useful commands:"
  echo "============================================"
  echo "  docker compose ps                     # which services are running"
  echo "  docker compose logs -f                # tail all logs"
  echo "  docker compose logs -f conductor      # tail one service"
  echo "  docker compose logs -f conductor | grep -v '^(CHARS_SENT'"
  echo "  docker compose down                   # stop (memory persists)"
  echo "  docker compose down -v                # stop + wipe memory"
  echo
  echo "Auth secret (send 'auth <secret>' to the bot once):"
  grep '^AUTH_SECRET=' "$ENV_FILE" | cut -d= -f2-
  echo
}

print_banner
prompt_telegram_token
prompt_provider
prompt_api_key
write_env_file
build_and_up
